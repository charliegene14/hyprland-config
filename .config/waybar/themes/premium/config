{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "height": 48,
  "spacing": 0,
  "margin-top": 8,
  "margin-left": 10,
  "margin-right": 10,
  "fixed-center": true,
  "modules-left": [
    "hyprland/workspaces",
    "custom/sep",
    "custom/window"
  ],
  "modules-center": [
    "custom/clock"
  ],
  "modules-right": [
    "custom/media",
    "custom/sep",
    "group/audio-pill",
    "custom/sep",
    "custom/mic-privacy",
    "custom/camera-privacy",
    "tray",
    "custom/vpn",
    "custom/idle",
    "custom/updates",
    "custom/powerprofile",
    "battery",
    "custom/notification",
    "custom/sep",
    "custom/ml4w-launcher"
  ],
  "group/audio-pill": {
    "orientation": "inherit",
    "modules": [
      "custom/mic",
      "backlight",
      "pulseaudio"
    ]
  },
  "custom/ml4w-launcher": {
    "format": "",
    "tooltip-format": "Gauche : Sidebar ML4W\nDroite : Welcome ML4W",
    "on-click": "qs ipc call sidebar toggle",
    "on-click-right": "qs ipc call welcome toggle"
  },
  "custom/sep": {
    "format": "│",
    "tooltip": false,
    "interval": "once"
  },
  "hyprland/workspaces": {
    "on-click": "activate",
    "all-outputs": true,
    "format": "{name}"
  },
  "custom/window": {
    "exec": "~/.config/waybar/themes/premium/scripts/window.sh",
    "return-type": "json",
    "escape": false,
    "markup": "pango"
  },
  "custom/clock": {
    "exec": "~/.config/waybar/themes/premium/scripts/clock.sh",
    "interval": 30,
    "tooltip": false,
    "escape": false,
    "markup": "pango",
    "on-click": "qs ipc call calendar toggle"
  },
  "custom/media": {
    "exec": "~/.config/waybar/themes/premium/scripts/media.sh",
    "interval": 2,
    "return-type": "json",
    "format": "{}",
    "escape": false,
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "tooltip-format": "{}"
  },
  "custom/mic": {
    "exec": "~/.config/waybar/themes/premium/scripts/mic.sh",
    "interval": 1,
    "return-type": "json",
    "format": "{}",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"
  },
  "backlight": {
    "format": "<span size='16pt' weight='400' font_family='Phosphor'></span>  <span rise='3500'>{percent}%</span>",
    "tooltip-format": "Luminosité : {percent}%",
    "on-scroll-up": "brightnessctl set 5%+",
    "on-scroll-down": "brightnessctl set 5%-"
  },
  "pulseaudio": {
    "format": "<span size='16pt' weight='400' font_family='Phosphor'></span>  <span rise='3500'>{volume}%</span>",
    "format-muted": "<span size='16pt' weight='400' font_family='Phosphor'></span>  <span rise='3500'>muet</span>",
    "format-bluetooth": "<span size='16pt' weight='400' font_family='Phosphor'></span>  <span rise='3500'>{volume}%</span>",
    "tooltip-format": "Volume : {volume}%\n{desc}",
    "scroll-step": 5,
    "on-click": "pavucontrol",
    "on-click-right": "pavucontrol"
  },
  "custom/powerprofile": {
    "exec": "~/.config/waybar/themes/premium/scripts/powerprofile.sh",
    "interval": 5,
    "signal": 11,
    "return-type": "json",
    "format": "{}",
    "on-click": "~/.config/waybar/themes/premium/scripts/powerprofile.sh cycle"
  },
  "battery": {
    "format": "<span size='16pt' weight='400' font_family='Phosphor'></span>  <span rise='3500'>{capacity}%</span>",
    "format-charging": "<span size='16pt' weight='400' font_family='Phosphor'></span>  <span rise='3500'>{capacity}%</span>",
    "format-plugged": "<span size='16pt' weight='400' font_family='Phosphor'></span>  <span rise='3500'>{capacity}%</span>",
    "format-alert": "<span size='16pt' weight='400' font_family='Phosphor'></span>  <span rise='3500'>{capacity}%</span>",
    "tooltip-format": "{capacity}% — {time}",
    "states": {
      "warning": 25,
      "critical": 10
    },
    "interval": 30
  },
  "custom/notification": {
    "tooltip-format": "Gauche : panneau\nDroite : Ne pas déranger",
    "format": "{icon}",
    "format-icons": {
      "notification": "",
      "none": "",
      "dnd-notification": "",
      "dnd-none": "",
      "inhibited-notification": "",
      "inhibited-none": "",
      "dnd-inhibited-notification": "",
      "dnd-inhibited-none": ""
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "tray": {
    "icon-size": 28,
    "spacing": 14
  },
  "custom/updates": {
    "format": "<span size='16pt' font_family='Phosphor'></span>  <span rise='3500'>{}</span>",
    "escape": true,
    "return-type": "json",
    "exec": "~/.config/ml4w/scripts/ml4w-check-system-updates",
    "interval": 1800,
    "signal": 1,
    "hide-empty-text": true,
    "tooltip-format": "Mises à jour disponibles\nGauche : installer\nDroite : centre logiciel",
    "on-click": "~/.config/ml4w/settings/installupdates.sh",
    "on-click-right": "~/.config/ml4w/settings/software.sh"
  },
  "custom/idle": {
    "exec": "~/.config/waybar/themes/premium/scripts/idle.sh",
    "interval": 5,
    "return-type": "json",
    "format": "{}",
    "on-click": "~/.config/hypr/scripts/hypridle.sh toggle"
  },
  "custom/vpn": {
    "exec": "~/.config/waybar/themes/premium/scripts/vpn.sh",
    "interval": 10,
    "return-type": "json",
    "format": "{}",
    "on-click": "nm-connection-editor"
  },
  "custom/mic-privacy": {
    "exec": "~/.config/waybar/themes/premium/scripts/mic-privacy.sh",
    "interval": 2,
    "return-type": "json",
    "format": "{}",
    "on-click": "pavucontrol"
  },
  "custom/camera-privacy": {
    "exec": "~/.config/waybar/themes/premium/scripts/camera-privacy.sh",
    "interval": 2,
    "return-type": "json",
    "format": "{}"
  }
}